        "resultados = model.train(\n",
        "    data=f\"{dataset.location}/data.yaml\",\n",
        "    epochs=25, # Cantidad de veces que repasará las imágenes (25 a 50 es un buen inicio)\n",
        "    imgsz=640, # Tamaño estándar de las imágenes\n",
        "    plots=True # Para que genere gráficas bonitas para tus evidencias\n",
        ")"
      ]
